{
  "name": "ptv",
  "version": "1.0.0",
  "description": "Melbourne PTV API CLI",
  "bin": {
    "ptv": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const f=require('fs'); f.cpSync('src/server/templates','dist/server/templates',{recursive:true}); f.cpSync('src/server/static-assets','dist/server/static-assets',{recursive:true})\" && npm run build:chat-web && node -e \"require('fs').cpSync('src/chat/static-assets','dist/chat/static-assets',{recursive:true})\"",
    "build:chat-web": "node web-chat/esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:browser": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pg": "^8.21.0",
    "qs": "^6.15.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.1",
    "cheerio": "^1.2.0",
    "esbuild": "^0.28.0",
    "ioredis-mock": "^8.13.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
